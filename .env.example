# MongoDB Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smartmart?retryWrites=true&w=majority

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_strong_random_secret_here_minimum_32_characters

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# NVIDIA AI API (OpenAI-compatible)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_AI_MODEL=deepseek-ai/deepseek-v4-pro

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Paystack (for payments)
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# OpenAI (if needed)
OPENAI_API_KEY=your_openai_api_key_here

# WhatsApp API (for customer engagement messages)
WHATSAPP_API_KEY=your_whatsapp_api_key_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
